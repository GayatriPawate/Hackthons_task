# Copy this file to .env and fill in the values.
# .env is git-ignored. Never commit real values.

# Set to false to connect to Member A's live backend.
USE_MOCK_DATA=true

# Base URL of Member A's FastAPI backend.
# Change this once Member A deploys to a shared environment.
API_BASE_URL=http://localhost:8000
SARVAM_API_KEY=
SARVAM_MODEL=sarvam-30b
